{
  "name": "app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "node server.mjs",
    "start:railway": "node server.mjs",
    "local-engine": "local_engine_windows\\run_local_engine.bat",
    "local-engine:install": "powershell -ExecutionPolicy Bypass -File local_engine_windows\\install_local_engine.ps1",
    "local-engine:package": "powershell -ExecutionPolicy Bypass -File local_engine_windows\\build_portable_release.ps1",
    "local-engine:diagnostics": "powershell -ExecutionPolicy Bypass -File local_engine_windows\\export_diagnostics.ps1",
    "local-engine:compare": "local_engine_windows\\.venv\\Scripts\\python.exe local_engine_windows\\compare_upstream.py"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "lucide-react": "^0.577.0",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "serve": "^14.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  }
}
